# 이 파일을 복사해서 .env 로 저장하고 값을 채우세요:  cp .env.example .env
GEMINI_API_KEY=AIza...여기에_발급받은_키...

# (선택) 사용할 모델. 기본값 gemini-flash-latest(항상 최신 Flash, EOS 걱정 없음).
# 특정 버전 고정: gemini-3.5-flash 등. `curl .../v1beta/models`로 사용 가능 목록 확인.
GEMINI_MODEL=gemini-flash-latest

# (선택) 포트. 기본값 3000
PORT=3000

# (선택, 배포 시 권장) Upstash Redis REST API — 설정하면 problems-db.json 대신
# 여기에 저장되어 컨테이너 재시작에도 데이터가 유지됩니다. 비우면 로컬 파일 사용.
# https://console.upstash.com 에서 무료 DB 생성 후 REST URL/TOKEN 복사.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
